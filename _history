","main.ts":"function clamp (v: number, lo: number, hi: number) {\n    if (v < lo) {\n        return lo\n    }\n    if (v > hi) {\n        return hi\n    }\n    return v\n}\nradio.onReceivedString(function (msg) {\n    rx = msg\n    parts = rx.split(\",\")\n    if (parts.length == 3) {\n        arm = parseInt(parts[0])\n        // expected range −100..+100\n        joyX = parseInt(parts[1])\n        joyY = parseInt(parts[2])\n    }\n})\n/**\n * BottleBoat Receiver — Proportional Rudder (−100..100 → ±MAX) + Throttle (mShield)\n * \n * Half stick = half angle; full stick = MAX_RUDDER_ANGLE\n */\nlet nextWriteAt = 0\nlet now = 0\nlet joyY = 0\nlet arm = 0\nlet parts: string[] = []\nlet rx = \"\"\nlet mag = 0\nlet joyX = 0\nlet RADIO_GROUP = 200\nradio.setGroup(RADIO_GROUP)\n// ===== USER SETTINGS =====\n// \"CW\" or \"CCW\"\nlet Forward_direction_motor = \"CW\"\nlet MIN_THROTTLE = 20\n// any neutral you need\nlet RUDDER_CENTER = 95\n// ± from center (deg)\nlet MAX_RUDDER_ANGLE = 45\n// small deadband\nlet X_DEAD = 3\n// write only if ≥ this many deg change\nlet ANGLE_EPS = 1\n// min time between writes near target\nlet WRITE_RATE_MS = 100\n// loop delay\nlet PAUSE_MS = 10\nlet fwdDirUse = mShield.MotorsDirection.CC\nlet revDirUse = mShield.MotorsDirection.CCW\nlet rudderAngle = RUDDER_CENTER\nlet target = RUDDER_CENTER\nlet minAngle = RUDDER_CENTER - MAX_RUDDER_ANGLE\nlet maxAngle = RUDDER_CENTER + MAX_RUDDER_ANGLE\nlet lastAngleCmd = RUDDER_CENTER\n// init\nmShield.wheelStop(mShield.Motors.AllMotors)\nmShield.setS1ToS4Type(mShield.S1ToS4Type.Servo)\nmShield.extendServoControl(mShield.PwmAndServoIndex.S4, mShield.ServoType.Servo180, RUDDER_CENTER)\nbasic.showString(\"RXV1-\" + RADIO_GROUP)\nbasic.forever(function () {\n    // map \"CW\"/\"CCW\"\n    if (Forward_direction_motor == \"CCW\" || Forward_direction_motor == \"ccw\") {\n        fwdDirUse = mShield.MotorsDirection.CCW\nrevDirUse = mShield.MotorsDirection.CC\n    } else {\n        fwdDirUse = mShield.MotorsDirection.CC\nrevDirUse = mShield.MotorsDirection.CCW\n    }\n    // arm LED\n    if (arm) {\n        led.plot(2, 2)\n    } else {\n        led.unplot(2, 2)\n    }\n    // ===== RUDDER: linear map from −100..100 to ±MAX_RUDDER_ANGLE =====\n    minAngle = RUDDER_CENTER - MAX_RUDDER_ANGLE\n    maxAngle = RUDDER_CENTER + MAX_RUDDER_ANGLE\n    let xCmd = (Math.abs(joyX) <= X_DEAD) ? 0 : clamp(joyX, -100, 100)\n// proportional mapping: ±100 → ±MAX_RUDDER_ANGLE\n    target = RUDDER_CENTER + Math.idiv(xCmd * MAX_RUDDER_ANGLE, 100)\n    // clamp final servo angle\n    target = clamp(target, minAngle, maxAngle)\n    target = clamp(target, 0, 180)\n    // write only if meaningfully changed or timer expired\n    now = control.millis()\n    if (Math.abs(target - lastAngleCmd) >= ANGLE_EPS || now >= nextWriteAt) {\n        rudderAngle = target\n        mShield.extendServoControl(mShield.PwmAndServoIndex.S4, mShield.ServoType.Servo180, rudderAngle)\n        lastAngleCmd = rudderAngle\n        nextWriteAt = now + WRITE_RATE_MS\n    }\n    // ===== THROTTLE from Y =====\n    if (arm) {\n        mag = Math.abs(joyY)\n        if (mag > 100) {\n            mag = 100\n        }\n        if (mag == 0) {\n            mShield.wheelStop(mShield.Motors.AllMotors)\n        } else {\n            if (mag < MIN_THROTTLE) {\n                mag = MIN_THROTTLE\n            }\n            if (joyY < 0) {\n                mShield.setMotorsDirectionSpeed(mShield.Motors.AllMotors, fwdDirUse, mag)\n            } else {\n                mShield.setMotorsDirectionSpeed(mShield.Motors.AllMotors, revDirUse, mag)\n            }\n        }\n    } else {\n        mShield.wheelStop(mShield.Motors.AllMotors)\n    }\n    basic.pause(PAUSE_MS)\n})\n","README.md":"","pxt.json":"{\n    \"name\": \"receiver-single-motor-v1-public\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"pxt_mshield\": \"github:siyeenove/pxt_mshield#v1.1.1\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"targetVersions\": {\n        \"branch\": \"stable8.0\",\n        \"tag\": \"v8.0.22\",\n        \"commits\": \"https://github.com/microsoft/pxt-microbit/commits/0657a603250be13848e043e55be26bb21bb0d9a7\",\n        \"target\": \"8.0.22\",\n        \"pxt\": \"12.0.19\"\n    },\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1780515532321,"editorVersion":"8.0.22","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"$zXzx]O:/ZoX]`ILkKvU\">rx</variable><variable id=\"_yo;jjdi^/%tHM=4@iEa\">msg</variable><variable id=\"#Pi,;GQp|}LgcW7ynaQ#\">parts</variable><variable id=\"HP9LehVZ.q|`#H!.d$Ye\">arm</variable><variable id=\"Xng%e#{FVgr-Eghv[_qz\">joyX</variable><variable id=\"Va%?}b5.e8zKdp,p8{FX\">joyY</variable><variable id=\"Pqvs?p))PxPv7}dc^^rl\">Forward_direction_motor</variable><variable id=\"z,2kF;R):qvLIWqne^Ij\">minAngle</variable><variable id=\";IUj{bgDM6^KQYY^kmcn\">RUDDER_CENTER</variable><variable id=\"}?XISIqz7=%X0=,B6S_|\">MAX_RUDDER_ANGLE</variable><variable id=\"PZTTWcu(2(E?$9W]eR=!\">maxAngle</variable><variable id=\"$^a`HSHp|aUjeyhLiYB^\">target</variable><variable id=\"}FB6V=F.X#g(`AGfda|5\">xCmd</variable><variable id=\"{TucXzyIIm5;r_f^[)[6\">now</variable><variable id=\"@rGf1]@O7]-PO:zm1~%e\">lastAngleCmd</variable><variable id=\"pNfdXfN~.ws,%o=hj=~1\">ANGLE_EPS</variable><variable id=\"MWC$xIo~IiJ|!HBkB)}!\">nextWriteAt</variable><variable id=\"B5;SYfGw+0O_61E9~(]v\">rudderAngle</variable><variable id=\"9c+jpz}rh1gWaa[,36Tf\">WRITE_RATE_MS</variable><variable id=\"@P#Kk%}(54QTlI~ie=rI\">mag</variable><variable id=\"@0`KbtHsvaZ)^h;BOeV/\">MIN_THROTTLE</variable><variable id=\"l#+13m58Uv_BkfPwi7_z\">PAUSE_MS</variable><variable id=\"0rfD^*~5Af,|auX1r3{.\">RADIO_GROUP</variable><variable id=\"YI=DoiK9+NRi{a^KnNl0\">X_DEAD</variable></variables><block type=\"pxt-on-star